FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends git gcc && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY functions/from-youtube/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY functions/from-youtube/ .
COPY scripts/k3s_runner.py /app/k3s_runner.py
CMD ["python", "k3s_runner.py"]
